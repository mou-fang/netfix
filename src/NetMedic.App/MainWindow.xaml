<Window x:Class="NetMedic.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:NetMedic.App"
        xmlns:res="clr-namespace:NetMedic.App.Resources"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="{x:Static res:Strings.AppTitle}"
        Height="520" Width="620"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <vm:PageToVisibilityConverter x:Key="PageToVis" />
        <vm:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <vm:NullToCollapsedConverter x:Key="NullToCollapsed" />
        <vm:FindingToTitleConverter x:Key="FindingTitle" />
        <vm:FindingToExplanationConverter x:Key="FindingExplanation" />
        <vm:RepairToTitleConverter x:Key="RepairTitle" />
        <vm:RepairToDescriptionConverter x:Key="RepairDesc" />
        <vm:RepairToConfirmConverter x:Key="RepairConfirm" />
        <vm:BoolToYesNoConverter x:Key="BoolToYesNo" />
    </Window.Resources>
    <Grid Margin="32">

        <!-- 首页 -->
        <StackPanel Visibility="{Binding CurrentPage, Converter={StaticResource PageToVis}, ConverterParameter=Home}">
            <TextBlock Text="{Binding AppName}" FontSize="28" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,16,0,4" />
            <TextBlock Text="{Binding AppVersion}" FontSize="13" Opacity="0.6"
                       HorizontalAlignment="Center" Margin="0,0,0,12" />
            <Border HorizontalAlignment="Center" Padding="14,6" CornerRadius="12"
                    Background="#E6F4EA" BorderBrush="#34A853" BorderThickness="1" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="#34A853" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ReadyState}" FontSize="13" FontWeight="Medium"
                               Foreground="#1B5E20" Margin="8,0,0,0" />
                </StackPanel>
            </Border>
            <TextBlock Text="{x:Static res:Strings.Home_SymptomPrompt}" FontSize="14"
                       HorizontalAlignment="Center" Margin="0,0,0,12" />
            <ListBox ItemsSource="{Binding SymptomOptions}"
                     SelectedItem="{Binding SelectedSymptomOption, Mode=TwoWay}"
                     HorizontalAlignment="Center" Margin="0,0,0,20"
                     BorderThickness="0" Background="Transparent">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="Padding" Value="8,4" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayText}" FontSize="13" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Button Content="{x:Static res:Strings.Home_StartCheckup}"
                    Command="{Binding StartCheckupCommand}"
                    Padding="28,12" FontSize="15" MinWidth="200"
                    HorizontalAlignment="Center" />
        </StackPanel>

        <!-- 体检中 -->
        <StackPanel Visibility="{Binding CurrentPage, Converter={StaticResource PageToVis}, ConverterParameter=Checking}">
            <TextBlock Text="{x:Static res:Strings.Checking}" FontSize="22" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,40,0,20" />
            <TextBlock Text="{Binding CurrentStageText}" FontSize="15"
                       HorizontalAlignment="Center" Margin="0,0,0,12" />
            <ProgressBar IsIndeterminate="True" Height="6" Margin="0,0,0,12" />
            <TextBlock Text="{Binding ProgressText}" FontSize="12" Opacity="0.7"
                       HorizontalAlignment="Center" Margin="0,0,0,24" />
            <Button Content="{x:Static res:Strings.Cancel}"
                    Command="{Binding CancelCheckupCommand}"
                    Padding="20,8" FontSize="13"
                    HorizontalAlignment="Center" />
        </StackPanel>

        <!-- 结果页 -->
        <StackPanel Visibility="{Binding CurrentPage, Converter={StaticResource PageToVis}, ConverterParameter=Result}">
            <TextBlock FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,8,0,12"
                       Text="{Binding PrimaryFinding, Converter={StaticResource FindingTitle}, Mode=OneWay}" />
            <TextBlock FontSize="13" Opacity="0.8" TextWrapping="Wrap" Margin="0,0,0,16"
                       Text="{Binding PrimaryFinding, Converter={StaticResource FindingExplanation}, Mode=OneWay}" />

            <!-- 推荐动作按钮 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                <Button Content="{x:Static res:Strings.SafeRepair}"
                        Command="{Binding RequestRepairCommand}"
                        Padding="20,10" FontSize="14" Margin="0,0,12,0"
                        Visibility="{Binding PrimaryFinding.RecommendedActionId, Converter={StaticResource NullToCollapsed}}" />
                <Button Content="{x:Static res:Strings.ViewGuidance}"
                        Command="{Binding GoHomeCommand}"
                        Padding="20,10" FontSize="14" />
            </StackPanel>

            <Button Content="{x:Static res:Strings.Retry}"
                    Command="{Binding GoHomeCommand}"
                    Padding="16,8" FontSize="12"
                    HorizontalAlignment="Center" Margin="0,0,0,16" />

            <!-- 技术详情折叠 -->
            <Button Content="{x:Static res:Strings.ShowTechnicalDetails}"
                    Command="{Binding ToggleTechnicalDetailsCommand}"
                    FontSize="11" Opacity="0.6" HorizontalAlignment="Left"
                    Margin="0,8,0,4"
                    Visibility="{Binding IsTechnicalDetailsVisible, Converter={StaticResource InverseBoolToVis}}" />
            <Button Content="{x:Static res:Strings.HideTechnicalDetails}"
                    Command="{Binding ToggleTechnicalDetailsCommand}"
                    FontSize="11" Opacity="0.6" HorizontalAlignment="Left"
                    Margin="0,8,0,4"
                    Visibility="{Binding IsTechnicalDetailsVisible, Converter={StaticResource BoolToVis}}" />
            <Border Visibility="{Binding IsTechnicalDetailsVisible, Converter={StaticResource BoolToVis}}"
                    BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,4,0,0"
                    MaxHeight="150">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding allFindings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,2">
                                    <TextBlock FontSize="11" Opacity="0.7">
                                        <Run Text="Finding: " /><Run Text="{Binding Id}" FontWeight="Medium" />
                                        <Run Text=" (" /><Run Text="{Binding Confidence}" /><Run Text=")" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <!-- 修复确认页 -->
        <StackPanel Visibility="{Binding CurrentPage, Converter={StaticResource PageToVis}, ConverterParameter=RepairConfirm}">
            <TextBlock Text="{x:Static res:Strings.RepairConfirm_Title}" FontSize="20" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,8,0,16" />
            <TextBlock FontSize="16" FontWeight="Medium" Margin="0,0,0,8"
                       Text="{Binding SelectedRepairAction, Converter={StaticResource RepairTitle}, Mode=OneWay}" />
            <TextBlock FontSize="13" Opacity="0.8" TextWrapping="Wrap" Margin="0,0,0,16"
                       Text="{Binding SelectedRepairAction, Converter={StaticResource RepairDesc}, Mode=OneWay}" />
            <Border BorderBrush="#EEE" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="{x:Static res:Strings.RepairConfirm_InterruptsNetwork}" FontSize="12" Width="160" />
                        <TextBlock FontSize="12" FontWeight="Medium"
                                   Text="{Binding SelectedRepairAction.InterruptsNetwork, Converter={StaticResource BoolToYesNo}}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="{x:Static res:Strings.RepairConfirm_NeedsAdmin}" FontSize="12" Width="160" />
                        <TextBlock FontSize="12" FontWeight="Medium"
                                   Text="{Binding SelectedRepairAction.RequiresElevation, Converter={StaticResource BoolToYesNo}}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="{x:Static res:Strings.RepairConfirm_NeedsReboot}" FontSize="12" Width="160" />
                        <TextBlock FontSize="12" FontWeight="Medium"
                                   Text="{Binding SelectedRepairAction.RequiresReboot, Converter={StaticResource BoolToYesNo}}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="{x:Static res:Strings.RepairConfirm_Reversible}" FontSize="12" Width="160" />
                        <TextBlock FontSize="12" FontWeight="Medium"
                                   Text="{Binding SelectedRepairAction.Reversible, Converter={StaticResource BoolToYesNo}}" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <TextBlock FontSize="12" Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,20"
                       Text="{Binding SelectedRepairAction, Converter={StaticResource RepairConfirm}, Mode=OneWay}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="{x:Static res:Strings.Confirm}"
                        Command="{Binding ConfirmRepairCommand}"
                        Padding="20,10" FontSize="14" Margin="0,0,12,0" />
                <Button Content="{x:Static res:Strings.Back}"
                        Command="{Binding GoHomeCommand}"
                        Padding="20,10" FontSize="14" />
            </StackPanel>
        </StackPanel>

        <!-- 修复结果页（假流程） -->
        <StackPanel Visibility="{Binding CurrentPage, Converter={StaticResource PageToVis}, ConverterParameter=RepairResult}">
            <TextBlock Text="{Binding ResultMessage}" FontSize="16"
                       TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,60,0,24" />
            <Button Content="{x:Static res:Strings.Done}"
                    Command="{Binding GoHomeCommand}"
                    Padding="20,10" FontSize="14"
                    HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
