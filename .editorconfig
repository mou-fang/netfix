root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,xml,xaml,csproj,props,targets}]
indent_size = 2

[*.{cs,csproj,props,targets}]
# C# files: dotnet format enforces style; keep 4-space indent.
indent_size = 4

[*.md]
trim_trailing_whitespace = false
